generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  avatar        String?
  oauthProvider String?   @map("oauth_provider")
  oauthId       String?   @map("oauth_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  ownedTeams       Team[]    @relation("TeamOwner")
  teamMembers      TeamMember[]
  diagrams         Diagram[]
  sharedWith       DiagramShare[]
  macros           UserMacro[]
  nodeTypes        NodeType[]
  comments         Comment[]
  commentReactions CommentReaction[]

  @@map("users")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")

  owner     User         @relation("TeamOwner", fields: [ownerId], references: [id])
  members   TeamMember[]
  diagrams  Diagram[]

  @@map("teams")
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String @map("team_id")
  userId String @map("user_id")
  role   String @default("member") // owner | admin | member

  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model Diagram {
  id          String   @id @default(cuid())
  name        String
  description String?
  data        Json     @default("{\"nodes\":[],\"edges\":[]}")
  thumbnail   String?
  isPublic    Boolean  @default(false) @map("is_public")
  createdById String   @map("created_by")
  teamId      String?  @map("team_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User           @relation(fields: [createdById], references: [id])
  team      Team?          @relation(fields: [teamId], references: [id])
  versions  DiagramVersion[]
  shares    DiagramShare[]
  comments  Comment[]

  @@map("diagrams")
}

model DiagramVersion {
  id        String   @id @default(cuid())
  diagramId String   @map("diagram_id")
  data      Json
  version   Int
  createdAt DateTime @default(now()) @map("created_at")

  diagram   Diagram  @relation(fields: [diagramId], references: [id], onDelete: Cascade)

  @@map("diagram_versions")
}

model DiagramShare {
  id        String  @id @default(cuid())
  diagramId String  @map("diagram_id")
  userId    String  @map("user_id")
  role      String  @default("viewer") // editor | viewer

  diagram   Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([diagramId, userId])
  @@map("diagram_shares")
}

model UserMacro {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  tags      String[] @default([])
  data      Json
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_macros")
}

model NodeType {
  id          String   @id @default(cuid())
  label       String
  category    String
  tech        String?
  description String?
  icon        String?
  color       String?
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  createdBy   User     @relation(fields: [createdById], references: [id])

  @@map("node_types")
}

model Comment {
  id          String   @id @default(cuid())
  diagramId   String   @map("diagram_id")
  authorId    String   @map("author_id")
  content     String?
  audioUrl    String?  @map("audio_url")
  type        String
  nodeId      String?  @map("node_id")
  posX        Float?   @map("pos_x")
  posY        Float?   @map("pos_y")
  parentId    String?  @map("parent_id")
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  diagram     Diagram  @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id])
  parent      Comment? @relation("CommentThread", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentThread")
  reactions   CommentReaction[]

  @@map("comments")
}

model CommentReaction {
  id         String   @id @default(cuid())
  commentId  String   @map("comment_id")
  userId     String   @map("user_id")
  emoji      String
  createdAt  DateTime @default(now()) @map("created_at")

  comment    Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@map("comment_reactions")
}
